    <!-- Scripts de interactividad -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const headers = document.querySelectorAll('.accordion-header');
            const toggleAllBtn = document.getElementById('toggleAllBtn');
            const toggleText = document.getElementById('toggleText');
            let allExpanded = false;

            // Manejo individual de cada acordeón
            headers.forEach(header => {
                header.addEventListener('click', () => {
                    const item = header.parentElement;
                    item.classList.toggle('active');
                });
            });

            // Expandir / Colapsar todos
            toggleAllBtn.addEventListener('click', () => {
                const items = document.querySelectorAll('.accordion-item');
                const icon = toggleAllBtn.querySelector('i');
                
                allExpanded = !allExpanded;
                
                items.forEach(item => {
                    if(allExpanded) {
                        item.classList.add('active');
                    } else {
                        item.classList.remove('active');
                    }
                });

                if(allExpanded) {
                    toggleText.textContent = 'Colapsar todo';
                    icon.classList.remove('ph-arrows-out-line-vertical');
                    icon.classList.add('ph-arrows-in-line-vertical');
                } else {
                    toggleText.textContent = 'Expandir todo';
                    icon.classList.remove('ph-arrows-in-line-vertical');
                    icon.classList.add('ph-arrows-out-line-vertical');
                }
            });

            // Abrir la primera sección por defecto para invitar a la lectura
            if(headers.length > 0) {
                setTimeout(() => {
                    headers[0].parentElement.classList.add('active');
                }, 800); // Se abre después de la animación de entrada
            }

            // Lógica de la barra de progreso de lectura (Scroll tracker)
            window.addEventListener('scroll', () => {
                const winScroll = document.body.scrollTop || document.documentElement.scrollTop;
                const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
                const scrolled = (winScroll / height) * 100;
                document.getElementById('scroll-progress').style.width = scrolled + '%';
            });
        });
    </script>
